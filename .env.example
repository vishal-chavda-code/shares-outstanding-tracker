# SEC EDGAR — include a descriptive user-agent per EDGAR fair-use policy
SEC_USER_AGENT="Your Name your-email@example.com"

# Polygon.io API key (free tier covers splits endpoint)
POLYGON_API_KEY="your_polygon_api_key_here"

# Financial Modeling Prep API key (free tier covers split calendar)
FMP_API_KEY="your_fmp_api_key_here"

# PostgreSQL connection string (leave blank to use Parquet/local storage instead)
DATABASE_URL="postgresql://user:password@localhost:5432/shares_outstanding"

# Optional: override default data directory
# DATA_DIR="./data"
